{
  "manifest_version": 3,
  "name": "Page Helper",
  "version": "1.0",
  "description": "Enhances browsing experience",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["fp-profile.js", "stealth.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
