# 数据库（docker compose 自动配置，仅本地开发需要）
DATABASE_URL=postgresql://nodeskpane:nodeskpane@localhost:5432/nodeskpane

# Selenium 基础镜像（Apple Silicon / ARM 用户必须取消注释下一行）
# SELENIUM_BASE_IMAGE=seleniarm/standalone-chromium:latest

# LLM（内置 Agent 用，CLI 用户可忽略）
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# 其他
MAX_STEPS=100
# DOCKER_HOST_ADDR=host.docker.internal  # Docker 部署自动设置，无需手动改
