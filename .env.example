# === 品牌 / 产品名称（改名只需改这里，重启后生效）===
# APP_TITLE=Remote Browser Playground
# APP_AGENT_NAME=NoDeskPane Agent
# CLI_COMMAND_NAME=nwb
# CLI_INSTALL_COMMAND=pip install nwb-cli
# CONTAINER_PREFIX=ndb
# SELENIUM_IMAGE_NAME=no-window-browser-selenium

# 数据库
# POSTGRES_USER=nodeskpane
# POSTGRES_PASSWORD=nodeskpane
# POSTGRES_DB=nodeskpane
DATABASE_URL=postgresql://nodeskpane:nodeskpane@localhost:5432/nodeskpane

# Selenium 基础镜像（Apple Silicon / ARM 用户取消注释）
# SELENIUM_BASE_IMAGE=seleniarm/standalone-chromium:latest

# LLM（内置 Agent 用）
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# 其他
MAX_STEPS=100

# 后端服务公开地址（内置存储生成的文件 URL 前缀，Docker 部署时需改为外部可达地址）
# API_BASE_URL=http://localhost:8000

# === 全面改名指南（代码级，仅在改 CLI 命令名/包名时需要）===
# 1. CLI 命令入口：cli/pyproject.toml [project.scripts] "nwb = ..."（改后 help/报错/配置目录自动跟随）
# 2. CLI 包目录：mv cli/nwb cli/<新名> + 更新 from nwb import（纯内部，用户不可见）
# 3. README.md / skills / .cursor/rules 文案
