# === 品牌 / 产品名称（改名只需改这里，重启后生效）===
# APP_TITLE=Browser Pilot
# CLI_COMMAND_NAME=bpilot
# CLI_INSTALL_COMMAND=pip install bpilot-cli
# CONTAINER_PREFIX=bp
# SELENIUM_IMAGE_NAME=browser-pilot-selenium

# 版本选择（Docker Compose 或直接运行后端/前端时可用；start.sh 无参数时会自动检测 ee/ 内容）
# EDITION=ce

# 数据库（本地开发示例；生产/公网部署必须修改密码）
# DATABASE_URL 需和 POSTGRES_* 保持一致；本地 start.sh 使用 localhost，Docker Compose 会使用 postgres 服务名。
POSTGRES_USER=bpilot
POSTGRES_PASSWORD=bpilot
POSTGRES_DB=bpilot
DATABASE_URL=postgresql://bpilot:bpilot@localhost:5432/bpilot

# 内置 S3 兼容对象存储（Docker Compose 默认 S3 存储；生产/公网部署必须修改密码）
MINIO_ROOT_USER=browserpilot
MINIO_ROOT_PASSWORD=browserpilot-change-me
MINIO_BUCKET=browser-pilot
# 本地 start.sh 默认使用 http://localhost:9000；Docker Compose backend 会自动覆盖为容器内对象存储地址
# MINIO_ENDPOINT=http://localhost:9000
# 客户端下载 S3/MinIO 预签名 URL 使用的公开地址；Docker Compose 默认映射到本机 9000
# MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Selenium 基础镜像（Apple Silicon / ARM 用户取消注释）
# SELENIUM_BASE_IMAGE=seleniarm/standalone-chromium:latest
# 可选 Cloak Chromium Runtime 镜像。首次使用前需构建：docker compose --profile build build cloak
# CLOAK_BROWSER_IMAGE_NAME=browser-pilot-cloak:latest
# Browser sessions that open on a blank/new-tab page are automatically sent here after start.
# BROWSER_HOME_URL=https://www.google.com/

# Session 自动命名（可选，配置后首次导航时用 LLM 生成 session 名称，不配置则用页面标题）
# OPENAI_API_KEY=sk-...

# 后端服务公开地址（内置存储生成的签名文件 URL 前缀，Docker 部署时需改为外部可达地址）
# API_BASE_URL=http://localhost:8000

# 后端访问浏览器容器的地址（Docker Compose 部署时自动设为 host.docker.internal，本地开发默认 localhost）
# DOCKER_HOST_ADDR=localhost

# 浏览器 runtime agent 回传后端 ingest API 的地址；浏览器容器内默认通过 host.docker.internal 访问宿主机 8000
# BROWSER_RUNTIME_BACKEND_URL=http://host.docker.internal:8000

# Docker Compose 运行时隔离：backend 通过内网 runtime-worker 管理浏览器容器，生产/公网部署必须修改 token。
BROWSER_RUNTIME_CONTROL_TOKEN=browserpilot-runtime-change-me
# BROWSER_RUNTIME_CONTROL_URL=http://runtime-worker:8001
# Large browser runtime images, especially Cloak Chromium, may need a long first build/pull.
# BROWSER_RUNTIME_COMMAND_MAX_TIMEOUT=3600

# 旧版 Docker 下载 watcher fallback（默认关闭；仅旧 Selenium 镜像没有 file-capture-agent 时临时启用）
# BP_LEGACY_DOCKER_DOWNLOAD_WATCHER=false

# 声明式网络画像（默认不做公网探针；未配置时会标记 network_profile_unverified）
# DEFAULT_NETWORK_COUNTRY_CODE=CN
# DEFAULT_NETWORK_COUNTRY=China
# DEFAULT_NETWORK_REGION=Zhejiang
# DEFAULT_NETWORK_CITY=Hangzhou
# DEFAULT_NETWORK_TIMEZONE=Asia/Shanghai
# DEFAULT_NETWORK_DNS_SERVERS=223.5.5.5,119.29.29.29

# 部署侧网络出口服务（用于托管 Clash / OpenVPN / 外部代理出口）
# NETWORK_EGRESS_DOCKER_NETWORK=browser-pilot-net
# NETWORK_EGRESS_CONFIG_DIR=data/network-egress
# NETWORK_EGRESS_CLASH_IMAGE=ghcr.io/metacubex/mihomo:latest
# NETWORK_EGRESS_CLASH_PROXY_PORT=7890
# NETWORK_EGRESS_OPENVPN_IMAGE=browser-pilot-openvpn-egress:latest
# NETWORK_EGRESS_OPENVPN_PROXY_PORT=8888

# 日志级别（DEBUG / INFO / WARNING / ERROR）
# LOG_LEVEL=INFO

# JWT 认证密钥（未设置时首次启动自动生成并写入 .env）
# JWT_SECRET=
# 短期访问 JWT 过期时间（分钟，默认 30）
# JWT_EXPIRE_MINUTES=30
# “免登录”记住此设备的天数（默认 7，使用可撤销的服务端 remember token，不拉长 JWT）
# REMEMBER_ME_DAYS=7

# === 全面改名指南（代码级，仅在改 CLI 命令名/包名时需要）===
# 1. CLI 命令入口：cli/pyproject.toml [project.scripts] "bpilot = ..."（改后 help/报错/配置目录自动跟随）
# 2. CLI 包目录：mv cli/bpilot cli/<新名> + 更新 from bpilot import（纯内部，用户不可见）
# 3. README.md / skills / .cursor/rules 文案
