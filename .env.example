# === 品牌 / 产品名称（改名只需改这里，重启后生效）===
# APP_TITLE=Browser Pilot
# CLI_COMMAND_NAME=bpilot
# CLI_INSTALL_COMMAND=pip install bpilot-cli
# CONTAINER_PREFIX=bp
# SELENIUM_IMAGE_NAME=browser-pilot-selenium

# 数据库
# POSTGRES_USER=bpilot
# POSTGRES_PASSWORD=bpilot
# POSTGRES_DB=bpilot
DATABASE_URL=postgresql://bpilot:bpilot@localhost:5432/bpilot

# Selenium 基础镜像（Apple Silicon / ARM 用户取消注释）
# SELENIUM_BASE_IMAGE=seleniarm/standalone-chromium:latest

# Session 自动命名（可选，配置后首次导航时用 LLM 生成 session 名称，不配置则用页面标题）
# OPENAI_API_KEY=sk-...

# 后端服务公开地址（内置存储生成的文件 URL 前缀，Docker 部署时需改为外部可达地址）
# API_BASE_URL=http://localhost:8000

# 后端访问浏览器容器的地址（Docker Compose 部署时自动设为 host.docker.internal，本地开发默认 localhost）
# DOCKER_HOST_ADDR=localhost

# 日志级别（DEBUG / INFO / WARNING / ERROR）
# LOG_LEVEL=INFO

# JWT 认证密钥（未设置时首次启动自动生成并写入 .env）
# JWT_SECRET=
# JWT 过期时间（分钟，默认 1440 = 24 小时）
# JWT_EXPIRE_MINUTES=1440

# === 全面改名指南（代码级，仅在改 CLI 命令名/包名时需要）===
# 1. CLI 命令入口：cli/pyproject.toml [project.scripts] "bpilot = ..."（改后 help/报错/配置目录自动跟随）
# 2. CLI 包目录：mv cli/bpilot cli/<新名> + 更新 from bpilot import（纯内部，用户不可见）
# 3. README.md / skills / .cursor/rules 文案
